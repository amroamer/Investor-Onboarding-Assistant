DATABASE_URL=postgresql://ioa:ioa@localhost:5432/ioa
UPLOAD_DIR=./uploads
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# AGENT_TYPE controls the conversation engine: "rule" (default) or "llm".
AGENT_TYPE=rule

# OpenSanctions API key — required for the compliance screening tab.
# Grab a key at https://www.opensanctions.org/api/ — they have a free tier
# for low-volume use; production needs a paid plan. Without this set,
# `Run screening` will fail with a 401 from the upstream API.
OPENSANCTIONS_API_KEY=
# Optional: override the base URL when running against a self-hosted instance.
# OPENSANCTIONS_BASE_URL=https://api.opensanctions.org
